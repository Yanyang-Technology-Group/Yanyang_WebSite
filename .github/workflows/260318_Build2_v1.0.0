name: Build Project

on:
  push:
    branches: [ "main", "master" ]
  pull_request:
    branches: [ "main", "master" ]
  # 允许手动触发
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    
    strategy:
      matrix:
        node-version: [20.x]  # 使用稳定的 Node.js 20
      fail-fast: false

    steps:
    # 检出代码
    - name: Checkout repository
      uses: actions/checkout@v4
    
    # 设置 Node.js
    - name: Setup Node.js ${{ matrix.node-version }}
      uses: actions/setup-node@v4
      with:
        node-version: ${{ matrix.node-version }}
        cache: 'npm'
    
    # 查看版本信息
    - name: Check versions
      run: |
        node --version
        npm --version
    
    # 安装依赖
    - name: Install dependencies
      run: |
        npm ci
      # 如果 npm ci 失败，尝试 npm install
      continue-on-error: true
      
    # 如果 npm ci 失败，使用 npm install
    - name: Install dependencies (fallback)
      if: steps.npm-ci.outcome == 'failure'
      run: npm install
    
    # 构建项目
    - name: Build project
      run: npm run build
      env:
        NODE_ENV: production
        CI: true
    
    # 检查构建结果
    - name: Check build output
      run: |
        if [ -d "dist" ]; then
          echo "✅ Build successful! dist folder created"
          ls -la dist/
        else
          echo "❌ Build failed: dist folder not found"
          exit 1
        fi
    
    # 上传构建产物
    - name: Upload build artifacts
      uses: actions/upload-artifact@v4
      with:
        name: dist-files
        path: dist/
        retention-days: 30
